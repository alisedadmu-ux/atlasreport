# Normalize line endings to keep diffs clean and deterministic across platforms.
# Text files are stored with LF in the repository.
* text=auto eol=lf

# Explicit text types
*.ts     text eol=lf
*.tsx    text eol=lf
*.js     text eol=lf
*.mjs    text eol=lf
*.cjs    text eol=lf
*.vue    text eol=lf
*.json   text eol=lf
*.css    text eol=lf
*.scss   text eol=lf
*.html   text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.svg    text eol=lf
*.sql    text eol=lf
*.env    text eol=lf

# Binary assets (never normalize)
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.webp   binary
*.ico    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.eot    binary
*.pdf    binary
